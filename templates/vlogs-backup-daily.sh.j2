#!/usr/bin/env bash
# Sync yesterday's VictoriaLogs partition to S3.
# Closed (non-current) partitions are immutable, so rclone sync directly
# from disk is safe and avoids depending on the snapshot HTTP API
# (which is not present in older VictoriaLogs versions).
set -euo pipefail

LOG_DIR="{{ vlogs_backup_log_dir }}"
mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/daily-$(date +%Y%m%d-%H%M%S).log"
exec > >(tee -a "$LOG_FILE") 2>&1

DATA_DIR="{{ vlogs_backup_data_dir }}"
RCLONE_CONF="{{ vlogs_backup_rclone_config_path }}"
REMOTE="{{ vlogs_backup_rclone_remote }}"
BUCKET="{{ vlogs_backup_s3_bucket }}"
PREFIX="{{ vlogs_backup_s3_prefix }}"
LAG_DAYS={{ vlogs_backup_daily_lag_days }}

TG_TOKEN="{{ vlogs_backup_telegram_bot_token }}"
TG_CHAT="{{ vlogs_backup_telegram_chat_id }}"
TG_NOTIFY_OK={{ vlogs_backup_telegram_notify_on_success | bool | ternary('1', '0') }}
HOST=$(hostname)
TARGET_DATE=""

tg_send() {
  local text="$1"
  [[ -z "${TG_TOKEN}" || -z "${TG_CHAT}" ]] && return 0
  curl -fsS --max-time 10 \
    -X POST "https://api.telegram.org/bot${TG_TOKEN}/sendMessage" \
    --data-urlencode "chat_id=${TG_CHAT}" \
    --data-urlencode "text=${text}" \
    --data-urlencode "parse_mode=Markdown" >/dev/null || true
}

on_exit() {
  local rc=$?
  if [[ $rc -eq 0 ]]; then
    [[ "${TG_NOTIFY_OK}" == "1" ]] || return 0
    tg_send "✅ *VictoriaLogs daily backup OK*
host: \`${HOST}\`
partition: \`${TARGET_DATE:-skipped}\`
bucket: \`${BUCKET}/${PREFIX}/${TARGET_DATE}\`"
  else
    local tail_log
    tail_log=$(tail -n 10 "${LOG_FILE}" 2>/dev/null | sed 's/[`*_]//g')
    tg_send "❌ *VictoriaLogs daily backup FAILED*
host: \`${HOST}\`
partition: \`${TARGET_DATE:-unknown}\`
exit code: \`${rc}\`
log tail:
\`\`\`
${tail_log}
\`\`\`"
  fi
}
trap on_exit EXIT

TARGET_DATE=$(date -u -d "${LAG_DAYS} days ago" +%Y%m%d)
echo "[$(date -Is)] Backing up partition ${TARGET_DATE}"

PARTITION_DIR="${DATA_DIR}/partitions/${TARGET_DATE}"
if [[ ! -d "${PARTITION_DIR}" ]]; then
  echo "Partition ${TARGET_DATE} does not exist on disk — skipping"
  exit 0
fi

rclone sync \
  --config="${RCLONE_CONF}" \
  --s3-no-check-bucket \
  --transfers=8 --checkers=16 \
  --stats=30s --stats-one-line \
  "${PARTITION_DIR}/" \
  "${REMOTE}:${BUCKET}/${PREFIX}/${TARGET_DATE}/"

echo "[$(date -Is)] Backup of ${TARGET_DATE} completed"
