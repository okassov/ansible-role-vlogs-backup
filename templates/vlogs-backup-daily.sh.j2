#!/usr/bin/env bash
# Sync yesterday's VictoriaLogs partition to S3.
# Closed (non-current) partitions are immutable, so rclone sync directly
# from disk is safe and avoids depending on the snapshot HTTP API
# (which is not present in older VictoriaLogs versions).
set -euo pipefail

LOG_DIR="{{ vlogs_backup_log_dir }}"
mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/daily-$(date +%Y%m%d-%H%M%S).log"
exec > >(tee -a "$LOG_FILE") 2>&1

DATA_DIR="{{ vlogs_backup_data_dir }}"
RCLONE_CONF="{{ vlogs_backup_rclone_config_path }}"
REMOTE="{{ vlogs_backup_rclone_remote }}"
BUCKET="{{ vlogs_backup_s3_bucket }}"
PREFIX="{{ vlogs_backup_s3_prefix }}"
LAG_DAYS={{ vlogs_backup_daily_lag_days }}

TARGET_DATE=$(date -u -d "${LAG_DAYS} days ago" +%Y%m%d)
echo "[$(date -Is)] Backing up partition ${TARGET_DATE}"

PARTITION_DIR="${DATA_DIR}/partitions/${TARGET_DATE}"
if [[ ! -d "${PARTITION_DIR}" ]]; then
  echo "Partition ${TARGET_DATE} does not exist on disk — skipping"
  exit 0
fi

rclone sync \
  --config="${RCLONE_CONF}" \
  --s3-no-check-bucket \
  --transfers=8 --checkers=16 \
  --stats=30s --stats-one-line \
  "${PARTITION_DIR}/" \
  "${REMOTE}:${BUCKET}/${PREFIX}/${TARGET_DATE}/"

echo "[$(date -Is)] Backup of ${TARGET_DATE} completed"
