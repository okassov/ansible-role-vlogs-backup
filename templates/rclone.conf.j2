[{{ vlogs_backup_rclone_remote }}]
type = s3
provider = Other
env_auth = false
access_key_id = {{ vlogs_backup_s3_access_key }}
secret_access_key = {{ vlogs_backup_s3_secret_key }}
endpoint = {{ vlogs_backup_s3_endpoint }}
region = {{ vlogs_backup_s3_region }}
acl = private
no_check_bucket = true
disable_checksum = true
